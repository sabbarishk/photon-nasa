# Copy this file to .env and fill in your values.
# .env is listed in .gitignore — never commit real keys.

# Required: Anthropic API key for LLM code generation.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required: AWS credentials for Lambda code execution.
# Create an IAM user with the policy in aws/README.md (lambda:InvokeFunction only).
# Get keys at: AWS Console → IAM → Users → your user → Security credentials → Access keys.
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=us-east-1

# Local dev only: set to 1 to skip API key authentication.
# Remove this line entirely in production.
PHOTON_SKIP_AUTH=1
